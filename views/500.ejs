<%- include('partials/header', { user: user || null }) %>

<div class="container text-center py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <img src="/favicon.jpg" alt="WirMax Solutions" style="height: 80px; margin-bottom: 20px;">
            <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
            <h1 class="display-4 mt-3">500</h1>
            <h2 class="mb-4">Internal Server Error</h2>
            <p class="lead">Something went wrong on our end. Please try again later.</p>
            <% if (error && process.env.NODE_ENV === 'development') { %>
                <div class="alert alert-danger mt-3">
                    <strong>Debug:</strong> <%= error %>
                </div>
            <% } %>
            <a href="/" class="btn btn-primary btn-lg px-4 mt-3">
                <i class="bi bi-house-door me-2"></i>Go to Homepage
            </a>
        </div>
    </div>
</div>

<%- include('partials/footer') %>